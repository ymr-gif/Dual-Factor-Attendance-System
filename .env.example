# nfc-scan configuration — copy to .env and edit. All values are optional;
# the defaults shown match the code. Nothing here is a secret by default.
# Load it however you run the service (e.g. systemd EnvironmentFile=, or `set -a; . ./.env`).

# --- Database (backend/db.py) ---
# Dev container default is localhost:5433 (see README). Override to point elsewhere.
DB_DSN=dbname=attendance user=attendance password=attendance host=localhost port=5433

# --- Face match, Step 6 (backend/face.py) ---
FACE_MATCH_ENABLED=true
FACE_THRESHOLD=0.5          # cosine cutoff; calibrate from logs
CAMERA_INDEX=0             # USB webcam; set 1 if it enumerates as video1
CAMERA_WARMUP_FRAMES=5
CAMERA_PROBE_FRAMES=5
MIN_FACE_PX=80
FACE_DET_SIZE=320          # detector input; raise (448/640) for far/small faces
USE_GPU=false             # drives BOTH face + liveness; auto-falls back to CPU

# --- Liveness / anti-spoof, Step 7 (backend/liveness.py) ---
LIVENESS_ENABLED=true
# LIVENESS_THRESHOLD=      # unset -> model argmax verdict; set a p_live cutoff after calibration
# LIVENESS_MODEL_DIR=      # defaults to backend/models/anti_spoof

# --- Guardian email, Step 8 (backend/notify.py) ---
NOTIFY_EMAIL_ENABLED=false # true -> email guardians; false -> console-only
SMTP_HOST=                # required to send
SMTP_PORT=587             # 465 -> implicit SSL, otherwise STARTTLS
SMTP_USER=                # omit for an open relay / local debug server
SMTP_PASSWORD=
SMTP_FROM=                # defaults to SMTP_USER
SMTP_STARTTLS=true
SMTP_TIMEOUT=10

# --- 2FA enforcement, Step 9 (backend/decision.py) ---
ENFORCE_2FA=false          # true -> a failed 2nd factor is rejected (not counted present)

# --- Serial reader (backend/serial_reader.py) ---
# TAP_URL=http://localhost:8001/tap
