# nfc-scan configuration — copy to .env and edit. All values are optional;
# the defaults shown match the code. Nothing here is a secret by default.
# Load it however you run the service (e.g. systemd EnvironmentFile=, or `set -a; . ./.env`).

# --- Database (backend/db.py) ---
# Dev container default is localhost:5433 (see README). Override to point elsewhere.
# Note: under `make up` (docker-compose) the backend reaches Postgres as host=db
# port=5432 — compose overrides this value, so leave it as-is for local runs.
# Quoted: the macOS launchd wrappers source this file with bash, where an unquoted
# value containing spaces splits into separate assignments (DB_DSN would silently
# truncate to "dbname=attendance" and libpq would fall back to a local socket).
DB_DSN="dbname=attendance user=attendance password=attendance host=localhost port=5433"

# --- Face match, Step 6 (backend/face.py) ---
FACE_MATCH_ENABLED=true
FACE_THRESHOLD=0.5          # cosine cutoff; calibrate from logs
# CAMERA_INDEX is optional. Left unset, the backend picks a camera itself: an external
# USB camera when one is plugged in, otherwise the built-in/laptop one. Set it to pin a
# specific index. Run `make cameras` to see what is attached and which index is used.
# CAMERA_INDEX=0
# CAMERA_PREFER_EXTERNAL=false   # always use the built-in camera instead
# CAMERA_AUTO=false              # never auto-select; use CAMERA_INDEX only
CAMERA_WARMUP_FRAMES=5
CAMERA_PROBE_FRAMES=5
MIN_FACE_PX=80
FACE_DET_SIZE=320          # detector input; raise (448/640) for far/small faces
USE_GPU=false             # drives BOTH face + liveness; auto-falls back to CPU

# --- Liveness / anti-spoof, Step 7 (backend/liveness.py) ---
LIVENESS_ENABLED=true
# LIVENESS_THRESHOLD=      # unset -> model argmax verdict; set a p_live cutoff after calibration
# LIVENESS_MODEL_DIR=      # defaults to backend/models/anti_spoof

# --- Guardian email, Step 8 (backend/notify.py) ---
NOTIFY_EMAIL_ENABLED=false # true -> email guardians; false -> console-only
SMTP_HOST=                # required to send
SMTP_PORT=587             # 465 -> implicit SSL, otherwise STARTTLS
SMTP_USER=                # omit for an open relay / local debug server
SMTP_PASSWORD=
SMTP_FROM=                # defaults to SMTP_USER
SMTP_STARTTLS=true
SMTP_TIMEOUT=10

# --- 2FA enforcement, Step 9 (backend/decision.py) ---
ENFORCE_2FA=false          # true -> a failed 2nd factor is rejected (not counted present)

# --- Perception service, Step 30 / Flow track (backend/perception.py) ---
# Continuous camera-owner pipeline (detect -> track -> recognize once per track).
# Default ON: camera runs at boot, /tap logs card-only `unverified` and enqueues
# for async face correlation (matcher, Step 31). Set false for headless / no-cam.
PERCEPTION_ENABLED=true
# PERCEPTION_SOURCE=         # unset -> CAMERA_INDEX; set a video file to run offline
TRACK_IOU_THRESH=0.3       # IoU to associate a detection with an existing track
TRACK_MAX_MISSES=15        # frames a track survives unmatched before it's dropped
PERCEPTION_FPS=15          # loop-rate cap

# --- Tap↔face matcher, Step 31 (backend/matcher.py) ---
# Correlates buffered taps with recognized faces within the window (Hungarian).
ASSOC_WINDOW_SEC=4         # keep wider than serial-buffering tap delay (design-notes §3)
TAP_COOLDOWN_SEC=2         # debounce duplicate/held-card reads per uid
# MATCH_THRESHOLD=         # cosine cutoff for tap↔face; defaults to FACE_THRESHOLD
# TAILGATE_NAME_THRESHOLD= # similarity to name a cardless tailgater; defaults to FACE_THRESHOLD
RESOLVE_INTERVAL_SEC=0.5   # how often the matcher resolves ripe taps/faces
MAX_FACE_BUFFER=256        # bounded face buffer (drop oldest under backpressure)

# --- Register guided-capture gate (GET /api/perception/state, Register.tsx) ---
# Live quality check from perception's own detections; drives capture-button gating.
REGISTER_BRIGHT_LOW=55     # mean face brightness (0–255) below this -> "not enough light"
REGISTER_BRIGHT_HIGH=215   # above this -> "too bright / backlit"
REGISTER_CENTER_MAX=0.45   # face-center offset (0 centered .. 1 edge) above this -> "center yourself"

# --- Identity & matching, Step 33 (backend/enroll.py) ---
# DUP_ENROLL_THRESHOLD=    # cosine at/above which enroll warns of a duplicate; defaults to FACE_THRESHOLD
REENROLL_AFTER_DAYS=0      # flag references older than N days for re-enroll (0 = off)

# --- Privacy & compliance, Step 20 (backend/privacy.py) ---
# Consent gate for minors' biometrics. OFF by default (dev/back-compat); turn ON in
# production BEFORE enrolling real children — then enroll + face match require a
# recorded face_consent (taps still log NFC-only without it).
FACE_CONSENT_REQUIRED=false
# Data retention (0/unset = keep forever). Applied by `make purge` (or a cron).
ATTENDANCE_RETENTION_DAYS=0   # delete whole logs older than N days
SCORE_RETENTION_DAYS=0        # null raw face/liveness scores older than N days (keep the row)

# --- Attendance sessions, Step 21 (backend/db.py) ---
# HH:MM cutoff for "late" marking on first check-in (empty = disabled)
LATE_CUTOFF=08:00

# --- Operator API + live tap stream, Step 11 (backend/main.py) ---
# Shared token guarding /api/* (reads + writes). Unset -> API is OPEN (dev only).
# Set a long random value in production. WebSocket /ws/taps passes it as ?token=.
# Send on REST as `Authorization: Bearer <token>` or `X-Operator-Token: <token>`.
OPERATOR_TOKEN=

# --- Serial reader (backend/serial_reader.py) ---
# TAP_URL=http://localhost:8001/tap
#
# SERIAL_PORT is optional. Left unset, the reader finds the board itself (preferring
# known USB vendors: Arduino, CH340, FTDI, CP210x) and re-resolves on every reconnect,
# so moving the board to another USB socket does not need a config change.
# Set it to pin one specific device when several boards are attached.
# Run `make ports` to see what is connected and which port would be opened.
# SERIAL_PORT=/dev/cu.usbmodem14201
# SERIAL_PORT_AUTO=false   # never auto-detect; use SERIAL_PORT only
