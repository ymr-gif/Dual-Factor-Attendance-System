# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtualenvs
.venv/
venv/
env/

# Local runtime state
backend/failed_taps.jsonl
*.log
*.launchd.log

# Model weights — fetched, not committed (sha256-pinned):
#   python -m backend.fetch_liveness_models
backend/models/

# Local Claude Code machine permissions (project CLAUDE.md is committed)
.claude/settings.local.json

# Stray WhatsApp-web cache (unrelated to this project)
.wwebjs_cache/

# Frontend (Step 12) — commit source, not deps or build output
frontend/node_modules/
frontend/dist/

# Env / secrets — commit .env.example, never .env
.env

# Deploy — local backups contain face templates (PII); never commit
backups/

# graphify — keep the graph outputs, drop the local cache + dated backups (noise)
graphify-out/cache/
graphify-out/20*/
graphify-out/.graphify_*

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# TS incremental build cache
frontend/tsconfig.tsbuildinfo
